{
    "label": "lock",
    "action": "hyprlock -c ~/.config/hypr/hyprlock.conf",
    "text": "Ḻock",
    "keybind": "l"
}
{
    "label": "reboot",
    "action": "hyprctl clients -j | jq -r '.[].pid' | xargs -r kill; systemctl reboot || loginctl reboot",
    "text": "Ṟeboot",
    "keybind": "r"
}
{
    "label": "shutdown",
    "action": "hyprctl clients -j | jq -r '.[].pid' | xargs -r kill; systemctl poweroff || loginctl poweroff",
    "text": "S̱hutdown",
    "keybind": "s"
}
{
    "label": "logout",
    "action": "hyprctl clients -j | jq -r '.[].pid' | xargs -r kill; pkill Hyprland || pkill sway || pkill niri || loginctl terminate-user $USER",
    "text": "Logouṯ",
    "keybind": "t"
}
{
    "label": "suspend",
    "action": "systemctl suspend || loginctl suspend",
    "text": "Su̱spend",
    "keybind": "u"
}
{
    "label": "hibernate",
    "action": "systemctl hibernate || loginctl hibernate",
    "text": "H̱ibernate",
    "keybind": "h"
}