{
  "clock": {
    "locale": "fr_FR.UTF-8",
    "format": "{:L%a %d %b %Y яАЧ %H:%M}",
    "tooltip-format": "{calendar}"
  },
  "cpu": {
    "format": "{usage}% яЛЫ"
  },
  "memory": {
    "format": "{}% ю┐Е"
  },
  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp2_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C яЛЗ",
    "format": "{temperatureC}┬░C яЛЙ"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "яЧз {capacity}%",
    "format-plugged": "яЗж {capacity}%",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ]
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "юОН",
      "юПУ",
      "юПС",
      "юПП",
      "юПО",
      "юПН",
      "юПК",
      "юПИ",
      "юОЫ"
    ]
  },
  "tray": {
    "spacing": 5
  },
  "temperature#cpu": {
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 90,
    "format-critical": "{temperatureC}┬░C яЛЗ",
    "format": "{temperatureC}┬░C яЛЙ",
    "tooltip-format": "CPU: {temperatureC}┬░C"
  },
  "temperature#gpu": {
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:03.1/0000:0b:00.0/0000:0c:00.0/0000:0d:00.0/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 90,
    "format-critical": "{temperatureC}┬░C яЛЗ",
    "format": "{temperatureC}┬░C яБн",
    "tooltip-format": "GPU: {temperatureC}┬░C"
  }
}
