{
  "hyprland/workspaces": {
    "all-outputs": false,
    "active-only": false,
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {}
  },
  "sway/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "urgent": ""
    }
  },
  "sway/mode": {
    "format": "{}"
  },
  "sway/window": {
    "format": "{}",
    "max-length": 40
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "rotate": 0,
    "icon-size": 18,
    "icon-theme": "Tela-circle-dracula",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  }
}
