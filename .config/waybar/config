{
  "layer": "top",
  "height": 24,
  "reload_style_on_change": true,
  "modules-left": [
    "sway/workspaces",
    "hyprland/workspaces",
    // "wlr/taskbar",
    "sway/mode"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "bluetooth",
    // "network",
    "cpu",
    "temperature",
    "memory",
    "backlight",
    "battery",
    "custom/headsetcontrol",
    // "custom/weather",
    "tray"
  ],

  "custom/weather": {
      "format": "{}┬░",
      "tooltip": true,
      "interval": 3600,
      "exec": "wttrbar --date-format \"%m/%d\" --lang fr --location Aubenas --hide-conditions",
      "return-type": "json"
  },
  "custom/headsetcontrol": {
      "format": "{}",
      "exec": "headsetcontrol -b 2>/dev/null | awk -F'Level:' '/Level/ {gsub(/[^0-9]/,\"\",$2); print $2\"% яЦР\"; exit}'",
      "tooltip": false,
      "interval": 3600,
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "rotate": 0,
    "icon-size": 18,
    "icon-theme": "Tela-circle-dracula",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "active-only": false,
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
    }
  },
  "sway/mode": {
    "format": "{}"
  },
  "sway/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "urgent": "яБк"
    }
  },
  "sway/window": {
    "format": "{}",
    "max-length": 40
  },
  "tray": {
    "spacing": 5
  },
  "clock": {
    "locale": "fr_FR.UTF-8",
    "format": "{:L%a %d %b %Y яАЧ %H:%M}",
    "tooltip-format": "{calendar}"
  },
  "cpu": {
    "format": "{usage}% яЛЫ"
  },


  "temperature": {
		"hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
		"input-filename": "temp2_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C яЛЗ",
    "format": "{temperatureC}┬░C яЛЙ"
  },
  "memory": {
    "format": "{}% яФ╕"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "яЧз {capacity}%",
    "format-plugged": "яЗж {capacity}%",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ]
  },
  "bluetooth": {
    "format": "яКФ {status}",
    "format-disabled": "",
    "format-connected": "яКФ {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connect├й(s)",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connect├й(s)\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "format-no-controller": "",
    "on-click": "blueman-manager"
  },
  "network": {
    "format-wifi": "яЗл",
    "format-ethernet": "яЮЦ",
    "tooltip-format": "{bandwidthDownBits} яАЩ {bandwidthUpBits} яВУ {essid} ({signalStrength}%)",
    "format-linked": "{ifname} (No IP) яЮЦ",
    "format-disconnected": "",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "max-length": 50
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}яКФ",
    "format-muted": "яЪй",
    "format-icons": {
      "headphones": "яЦП",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАз",
        "яАи"
      ]
    },
    "on-click": "pactl set-default-sink $(pactl list short sinks | grep -v \"$(pactl info | grep 'Default Sink' | cut -d' ' -f3)\" | head -n1 | cut -f2)",
    "on-click-right": "pavucontrol"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "юОН",
      "юПУ",
      "юПС",
      "юПП",
      "юПО",
      "юПН",
      "юПК",
      "юПИ",
      "юОЫ"
    ]
  }
}
