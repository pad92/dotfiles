#!/bin/bash

if [ -z "$3" ]; then
  echo "3 arguments expected." >&2
  echo "Usage:" >&2
  echo "  $0 <left> <right> <cmd>" >&2
  echo "  The token IN in <cmd> will be replaced with each file path." >&2
  exit 1
fi

CMD=$3
CMD1="${CMD/IN/$1}"
CMD2="${CMD/IN/$2}"

diff -wB --label "$1" --label "$2" -u <(bash -c "$CMD1") <(bash -c "$CMD2")
