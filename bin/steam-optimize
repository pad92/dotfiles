# --- Helpers ---

def run_silent(cmd):
    """Executes a command silently, ignoring output and failures."""
    try:
        subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception:
        return False

# --- Notification Collector ---

class NotificationCollector:
    def __init__(self):
        self.collecting = False
        self.gpu = None
        self.hyprland = None
        self.overrides = None
        self.gamescope = None
        self.mangohud = False
        self.warnings = []
        self.errors = []
        self.game_name = "Game"

    def start(self, game_name="Game"):
        self.collecting = True
        self.game_name = game_name
        self.gpu = None
        self.hyprland = None
        self.overrides = None
        self.gamescope = None
        self.mangohud = False
        self.warnings = []
        self.errors = []

    def add_warning(self, msg):
        if msg not in self.warnings:
            self.warnings.append(msg)

    def add_error(self, msg):
        if msg not in self.errors:
            self.errors.append(msg)

    def get_startup_message(self):
        lines = [f"🎮 Steam Optimize: {self.game_name}", ""]
        
        bullets = []
        if self.gpu:
            bullets.append(f"  • GPU: {self.gpu}")
        if self.gamescope:
            bullets.append(f"  • Gamescope: {self.gamescope}")
        if self.hyprland:
            bullets.append(f"  • Hyprland: {self.hyprland}")
        if self.overrides:
            bullets.append(f"  • Overrides: {self.overrides}")
        if self.mangohud:
            bullets.append("  • HUD: MangoHud (horizontal top bar)")
        
        lines.extend(bullets)
            
        if self.warnings or self.errors:
            lines.append("")
            if self.warnings:
                warn_msg = "; ".join(self.warnings)
                lines.append(f"  ⚠️ Warning: {warn_msg}")
            if self.errors:
                err_msg = "; ".join(self.errors)
                lines.append(f"  ❌ Error: {err_msg}")
            
        return "\n".join(lines)

collector = NotificationCollector()

# --- Logging ---

def log_msg(level, icon, msg):
    steam_app_id = os.environ.get("SteamAppId", "")
    tag = "steam-optimize"
    
    log_text = f"{level} [{steam_app_id}] {msg}"
    run_silent(["logger", "-t", tag, log_text])
        
    if icon is None:
        return
        
    if collector.collecting:
        if level == "WARN":
            collector.add_warning(msg)
        elif level == "ERROR":
            collector.add_error(msg)
        return
            
    run_silent(["notify-send", msg])

def log_info_silent(msg): log_msg("INFO", None, msg)
def log_info(msg):        log_msg("INFO", 1, msg)
def log_warn(msg):        log_msg("WARN", 0, msg)
def log_error(msg):       log_msg("ERROR", 3, msg)

# --- Global Environment Setup ---

def check_gamescope_supports_output():
    try:
        res = subprocess.run(["gamescope", "--help"], capture_output=True, text=True)
        help_text = res.stdout + res.stderr
        return "--prefer-output" in help_text
    except Exception:
        return False

def setup_global_env():
    # Raise open file descriptor limit
    try:
        import resource
        soft, hard = resource.getrlimit(resource.RLIMIT_NOFILE)
        target = min(1048576, hard)
        resource.setrlimit(resource.RLIMIT_NOFILE, (target, hard))
    except Exception as e:
        log_warn(f"Failed to raise ulimit: {e}")

    # Set common variables
    os.environ.update(COMMON_ENV_VARS)

    gpu_detected = False

    if os.path.isdir("/sys/module/amdgpu"):
        log_info("AMD GPU detected (amdgpu module loaded) — applying RADV optimizations")
        os.environ.update(AMD_ENV_VARS)
        gpu_detected = True
        collector.gpu = "AMD (RADV driver)"

    if os.path.isdir("/sys/module/nvidia"):
        log_info("NVIDIA GPU detected (nvidia module loaded) — applying proprietary optimizations")
        os.environ.update(NVIDIA_ENV_VARS)
        gpu_detected = True
        collector.gpu = "NVIDIA (Proprietary driver)"

    if not gpu_detected:
        log_warn("No specific GPU module (amdgpu/nvidia) detected — using common defaults")
        collector.gpu = "Generic (Common defaults)"

    gamescope_supports_output = check_gamescope_supports_output()
    if not gamescope_supports_output:
        log_warn("Gamescope does not support -O/--prefer-output; monitor pinning will be skipped")
        
    return gamescope_supports_output

# --- Hyprland Integration ---

def setup_hyprland_env():
    user_id = os.getuid()
    runtime_dir = f"/run/user/{user_id}"
    os.environ["XDG_RUNTIME_DIR"] = runtime_dir
    
    hypr_dir = os.path.join(runtime_dir, "hypr")
    if os.path.isdir(hypr_dir):
        try:
            items = os.listdir(hypr_dir)
            if items:
                items_with_time = [(os.path.join(hypr_dir, x), x) for x in items]
                items_with_time.sort(key=lambda x: os.path.getmtime(x[0]), reverse=True)
                os.environ["HYPRLAND_INSTANCE_SIGNATURE"] = items_with_time[0][1]
        except Exception:
            pass

def get_gamescope_args(monitor_selector, gamescope_supports_output):
    args = ["-f", "--force-grab-cursor"]
    
    if not os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        collector.gamescope = "Enabled (Default settings)"
        return args

    try:
        res = subprocess.run(["hyprctl", "monitors", "-j"], capture_output=True, text=True)
        if res.returncode != 0 or not res.stdout:
            collector.gamescope = "Enabled (Default, query failed)"
            return args
        monitors = json.loads(res.stdout)
    except Exception as e:
        log_warn(f"Failed to query hyprctl: {e}")
        collector.gamescope = "Enabled (Default, query error)"
        return args

    target_monitor = None
    if monitor_selector == "focused":
        target_monitor = next((m for m in monitors if m.get("focused")), None)
    elif monitor_selector.startswith("workspace:"):
        try:
            ws_id = int(monitor_selector.split(":")[1])
            target_monitor = next((m for m in monitors if m.get("activeWorkspace", {}).get("id") == ws_id), None)
        except Exception:
            pass
    else:
        target_monitor = next((m for m in monitors if m.get("name") == monitor_selector), None)

    if not target_monitor:
        log_warn(f"Monitor '{monitor_selector}' not found; using default Gamescope settings.")
        collector.gamescope = "Enabled (Default, monitor not found)"
        return args

    w = target_monitor.get("width")
    h = target_monitor.get("height")
    name = target_monitor.get("name")
    refresh = target_monitor.get("refreshRate")

    if w and h:
        args = ["-W", str(w), "-H", str(h), "-w", str(w), "-h", str(h)] + args

    r_rate = 0
    if refresh:
        r_rate = int(round(refresh))
        if r_rate > 0:
            args.append("-r")
            args.append(str(r_rate))

    if name and gamescope_supports_output:
        args.append("-O")
        args.append(name)

    # Format gamescope info cleanly
    res_str = f"{w}x{h}" if (w and h) else "auto"
    ref_str = f" @ {r_rate}Hz" if r_rate > 0 else ""
    out_str = f" on {name}" if name and gamescope_supports_output else ""
    collector.gamescope = f"Enabled ({res_str}{ref_str}{out_str})"

    return args

def hyprland_start():
    if not os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        return

    log_info("Optimizing Hyprland for gaming")
    run_silent(["makoctl", "mode", "-s", "dnd"])

    eval_cmd = """
      hl.config({
        animations = { enabled = false },
        decoration = {
          rounding = 0,
          active_opacity = 1.0,
          inactive_opacity = 1.0,
          shadow = { enabled = false },
          blur = { enabled = false }
        }
      })
    """
    if run_silent(["hyprctl", "eval", eval_cmd]):
        collector.hyprland = "Optimized (DND, animations/blur disabled)"
    else:
        log_warn("Failed to apply Hyprland rendering optimizations (hl.config unavailable?)")
        collector.hyprland = "Optimized (DND active, rendering tweaks failed)"

def hyprland_end():
    run_silent(["razer-cli", "-d", "1600"])
    success = True

    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        log_info_silent("Restoring Hyprland configuration")
        if not run_silent(["hyprctl", "reload"]):
            log_msg("ERROR", None, "Failed to reload Hyprland configuration")
            success = False
        run_silent(["makoctl", "mode", "-s", "default"])

    return success

# --- Game Configuration Helpers & Overrides ---

def apply_game_overrides(steam_app_id, game_cmd):
    cmd = list(game_cmd)
    profile = GAME_PROFILES.get(steam_app_id)

    if not profile:
        game_name = f"AppID:{steam_app_id}" if steam_app_id else "UnknownGame"
        log_info("No game-specific overrides; using default settings")
        collector.overrides = "None (Defaults)"
        return game_name, cmd

    game_name = profile.get("name", "UnknownGame")
    
    # Apply mouse DPI
    dpi = profile.get("dpi")
    if dpi:
        run_silent(["razer-cli", "-d", str(dpi)])

    # Apply wayland
    if profile.get("wayland"):
        os.environ.pop("SDL_VIDEODRIVER", None)
        os.environ.pop("__GLX_VENDOR_LIBRARY_NAME", None)
        if not profile.get("keep_steaminput"):
            os.environ["PROTON_NO_STEAMINPUT"] = "1"
        log_info(f"Applying native Wayland optimizations for {game_name}")

    # Apply BattlEye
    if profile.get("battleye"):
        be_path = find_battleye_runtime()
        if not be_path:
            steam_root = find_steam_root()
            default_root = steam_root if steam_root else os.path.expanduser("~/.local/share/Steam")
            be_path = os.path.join(default_root, "steamapps", "common", "Proton BattlEye Runtime")
            log_warn(f"Proton BattlEye Runtime not found in Steam libraries. Falling back to default: {be_path}")
        os.environ["PROTON_BATTLEYE_RUNTIME"] = be_path
        os.environ["PROTON_BATTLEYE_RUNTIME_ALWAYS_COPY"] = "1"
        os.environ["PROTON_BATTLEYE_RUNTIME_LEGACY_EXEC"] = "1"
        log_info(f"Applying BattlEye overrides for {game_name}")

    if profile.get("no_steaminput"):
         os.environ["PROTON_NO_STEAMINPUT"] = "1"

    # Environment variables
    env_vars = profile.get("env")
    if env_vars:
        os.environ.update(env_vars)

    pop_env = profile.get("pop_env")
    if pop_env:
        for key in pop_env:
            os.environ.pop(key, None)

    # Command line args
    cmd_args = profile.get("cmd_args")
    if cmd_args:
        cmd.extend(cmd_args)

    # Format notification message
    if "override_label" in profile:
        collector.overrides = profile["override_label"]
    elif profile.get("wayland"):
        keep_str = " (SteamInput kept)" if profile.get("keep_steaminput") else ""
        dpi_str = f", mouse DPI {dpi}" if dpi else ""
        collector.overrides = f"Wayland{keep_str}{dpi_str}"
    elif profile.get("battleye"):
        dpi_str = f", mouse DPI {dpi}" if dpi else ""
        collector.overrides = f"BattlEye{dpi_str}"
    elif env_vars:
        env_keys = ", ".join(env_vars.keys())
        collector.overrides = f"Env: {env_keys}"
    else:
        collector.overrides = "Custom config"

    return game_name, cmd

# --- Interactive Installer (Factorized) ---

def find_steam_root():
    paths = [
        os.path.expanduser("~/.local/share/Steam"),
        os.path.expanduser("~/.steam/steam"),
        os.path.expanduser("~/.steam/root"),
    ]
    for p in paths:
        if os.path.isdir(p) and os.path.exists(os.path.join(p, "steamapps", "libraryfolders.vdf")):
            return p
    return None

def find_library_folders(steam_root, vdf_module=None):
    lib_vdf = os.path.join(steam_root, "steamapps", "libraryfolders.vdf")
    if not os.path.isfile(lib_vdf):
        return [steam_root]
    
    folders = []
    if vdf_module:
        try:
            with open(lib_vdf, "r") as f:
                data = vdf_module.load(f)
            for k, v in data.get("libraryfolders", {}).items():
                if "path" in v:
                    folders.append(v["path"])
        except Exception as e:
            print(f"Warning: Error reading libraryfolders.vdf with vdf module ({e}). Falling back to manual parsing.", file=sys.stderr)
            
    if not folders:
        try:
            with open(lib_vdf, "r") as f:
                for line in f:
                    if '"path"' in line:
                        parts = line.split('"')
                        if len(parts) >= 4:
                            folders.append(parts[3])
        except Exception:
            pass
            
    return folders if folders else [steam_root]

def find_battleye_runtime():
    steam_root = find_steam_root()
    if not steam_root:
        return None
    library_folders = find_library_folders(steam_root)
    for folder in library_folders:
        be_path = os.path.join(folder, "steamapps", "common", "Proton BattlEye Runtime")
        if os.path.isdir(be_path):
            return be_path
    return None

def find_localconfig_paths(steam_root):
    userdata_dir = os.path.join(steam_root, "userdata")
    if not os.path.isdir(userdata_dir):
        return []
    paths = []
    for d in os.listdir(userdata_dir):
        if d.isdigit():
            vdf_path = os.path.join(userdata_dir, d, "config", "localconfig.vdf")
            if os.path.isfile(vdf_path):
                paths.append(vdf_path)
    return paths

def get_installed_games(library_folders, vdf_module):
    games = {}
    for folder in library_folders:
        steamapps_dir = os.path.join(folder, "steamapps")
        if not os.path.isdir(steamapps_dir):
            continue
        for filename in os.listdir(steamapps_dir):
            if filename.startswith("appmanifest_") and filename.endswith(".acf"):
                acf_path = os.path.join(steamapps_dir, filename)
                try:
                    with open(acf_path, "r") as f:
                        manifest = vdf_module.load(f)
                    app_state = manifest.get("AppState", {})
                    appid = app_state.get("appid")
                    name = app_state.get("name")
                    if appid and name:
                        name_lower = name.lower()
                        exclude_keywords = [
                            "steam linux runtime",
                            "proton",
                            "steamworks",
                            "steamvr",
                            "steam controller configs"
                        ]
                        if not any(kw in name_lower for kw in exclude_keywords):
                            games[appid] = name
                except Exception:
                    pass
    return games

def is_steam_running():
    try:
        res = subprocess.run(["pgrep", "-x", "steam"], capture_output=True)
        return res.returncode == 0
    except Exception:
        return False

def shutdown_steam():
    if not is_steam_running():
        return True
    
    print("\n\033[93m⚠️  Steam is currently running.\033[0m")
    print("\033[93mGracefully shutting down Steam to safely modify configurations...\033[0m")
    
    run_silent(["steam", "-shutdown"])
    
    for _ in range(30):
        time.sleep(0.5)
        if not is_steam_running():
            print("\033[92m✓ Steam has been shut down successfully.\033[0m\n")
            return True
            
    print("\033[91mSteam did not shut down in time. Sending termination signal (SIGTERM)...\033[0m")
    run_silent(["pkill", "-x", "steam"])
        
    for _ in range(10):
        time.sleep(0.5)
        if not is_steam_running():
            print("\033[92m✓ Steam has been shut down.\033[0m\n")
            return True
            
    print("\033[91m❌ Unable to shut down Steam. Please close it manually and run the command again.\033[0m")
    return False

def get_app_entry(config, appid):
    """Retrieves or creates a mutable dictionary for a given AppID in a VDF config."""
    apps = config.setdefault("UserLocalConfigStore", {}).setdefault("Software", {}).setdefault("Valve", {}).setdefault("Steam", {}).setdefault("apps", {})
    entry = apps.setdefault(appid, {})
    if not isinstance(entry, dict):
        apps[appid] = {}
        entry = apps[appid]
    return entry

def get_app_entry_safe(config, appid):
    """Safely retrieves a dictionary for a given AppID in a VDF config if it exists."""
    apps = config.get("UserLocalConfigStore", {}).get("Software", {}).get("Valve", {}).get("Steam", {}).get("apps", {})
    if apps and isinstance(apps, dict):
        entry = apps.get(appid)
        if isinstance(entry, dict):
            return entry
    return None

def run_installer(script_path):
    # Check if the script is in PATH to warn the user if they can't run it globally
    script_name = os.path.basename(script_path)
    is_in_path = shutil.which(script_name) is not None
    if not is_in_path:
        print(f"\033[93m⚠️  Warning: '{script_name}' is not in your PATH.\033[0m")
        print(f"\033[93m   To launch it globally, consider adding its directory to your PATH:")
        print(f"   export PATH=\"{os.path.dirname(script_path)}:$PATH\"\033[0m\n")

    try:
        import vdf as vdf_module
    except ImportError:
        print("Error: The python 'vdf' module is required for the installer.", file=sys.stderr)
        print("Please install it with: pip install vdf", file=sys.stderr)
        sys.exit(1)

    target_option_no_hud = f"{script_path} -- %command%"
    target_option_hud = f"{script_path} --mangohud -- %command%"

    steam_root = find_steam_root()
    if not steam_root:
        print("\033[91m❌ Error: Unable to find Steam installation folder.\033[0m", file=sys.stderr)
        sys.exit(1)

    localconfig_paths = find_localconfig_paths(steam_root)
    if not localconfig_paths:
        print("\033[91m❌ Error: No localconfig.vdf file found in userdata.\033[0m", file=sys.stderr)
        sys.exit(1)

    if not shutdown_steam():
        sys.exit(1)

    vdf_configs = {}
    for path in localconfig_paths:
        try:
            with open(path, "r") as f:
                vdf_configs[path] = vdf_module.load(f)
        except Exception as e:
            print(f"\033[91m❌ Unable to read {path}: {e}\033[0m", file=sys.stderr)

    if not vdf_configs:
        print("\033[91m❌ Error: No localconfig.vdf configuration files could be loaded.\033[0m", file=sys.stderr)
        sys.exit(1)

    library_folders = find_library_folders(steam_root, vdf_module)
    installed_games = get_installed_games(library_folders, vdf_module)

    if not installed_games:
        print("\033[93m⚠️ No installed Steam games detected.\033[0m")
        sys.exit(0)

    games_list = sorted(installed_games.items(), key=lambda x: x[1].lower())
    dirty = False

    while True:
        launch_options_by_app = {}
        for appid, _ in games_list:
            opts = []
            for path, config in vdf_configs.items():
                apps = config.get("UserLocalConfigStore", {}).get("Software", {}).get("Valve", {}).get("Steam", {}).get("apps", {})
                app_data = apps.get(appid, {})
                if isinstance(app_data, dict) and "LaunchOptions" in app_data:
                    opts.append(app_data["LaunchOptions"])
                else:
                    opts.append("")
            
            if len(set(opts)) == 1:
                launch_options_by_app[appid] = opts[0]
            else:
                launch_options_by_app[appid] = opts[0] if opts else ""

        os.system("clear")
        print("=" * 85)
        print(f"\033[1;96m{'STEAM-OPTIMIZE INTERACTIVE CONFIGURATOR':^85}\033[0m")
        print("=" * 85)
        print(f"{'#':<4} | {'Game Name':<42} | {'AppID':<10} | {'Launch Options / Status'}")
        print("-" * 85)

        for idx, (appid, name) in enumerate(games_list, 1):
            current_options = launch_options_by_app.get(appid, "")
            if current_options == target_option_no_hud:
                status = f"\033[92m[Optimized (steam-optimize)]\033[0m"
            elif current_options == target_option_hud:
                status = f"\033[92m[Optimized + MangoHud]\033[0m"
            elif current_options:
                status = f"\033[93m[Other: {current_options}]\033[0m"
            else:
                status = f"\033[90m[Not optimized]\033[0m"

            print(f"{idx:<4} | {name[:42]:<42} | {appid:<10} | {status}")

        print("-" * 85)
        print("\033[1mOptions:\033[0m")
        print("  \033[96m[t]\033[0m     Toggle optimization for a specific game (Cycles: Off -> On -> On + MangoHud)")
        print("  \033[96m[e]\033[0m     Enable optimization for ALL games")
        print("  \033[96m[d]\033[0m     Disable/Remove optimization for ALL games")
        print("  \033[96m[m]\033[0m     Toggle MangoHud for all currently optimized games")
        print("  \033[96m[s]\033[0m     Save changes and exit")
        print("  \033[96m[c]\033[0m     Cancel and exit without saving")
        print("=" * 85)

        if dirty:
            print("\033[93m⚠️  You have unsaved changes. Press 's' to save them.\033[0m")

        choice = input("\nChoose an option or enter a game number: ").strip().lower()

        if choice == "s":
            if dirty:
                print("\nSaving configurations...")
                for path, config in vdf_configs.items():
                    try:
                        with open(path, "w") as f:
                            vdf_module.dump(config, f, pretty=True)
                        print(f"\033[92m✓ Saved: {path}\033[0m")
                    except Exception as e:
                        print(f"\033[91m❌ Error saving {path}: {e}\033[0m", file=sys.stderr)
                print("\n\033[92m✓ Installation complete! You can now restart Steam.\033[0m")
            else:
                print("\nNo changes to save.")
            break

        elif choice == "c":
            print("\nChanges cancelled.")
            break

        elif choice == "e":
            # Prompt the user to choose if they want to enable MangoHud for all games
            mango_choice = input("\nEnable MangoHud for these optimizations? (y/n) [y]: ").strip().lower()
            target_to_use = target_option_no_hud if mango_choice == "n" else target_option_hud
            for appid, _ in games_list:
                for path, config in vdf_configs.items():
                    get_app_entry(config, appid)["LaunchOptions"] = target_to_use
            dirty = True
            hud_status = "with MangoHud" if target_to_use == target_option_hud else "without MangoHud"
            print(f"\nEnabled for all games ({hud_status}).")
            time.sleep(1)

        elif choice == "d":
            for appid, _ in games_list:
                for path, config in vdf_configs.items():
                    entry = get_app_entry_safe(config, appid)
                    if entry and entry.get("LaunchOptions") in (target_option_no_hud, target_option_hud):
                        entry.pop("LaunchOptions", None)
            dirty = True
            print("\nDisabled for all games.")
            time.sleep(1)

        elif choice == "m":
            any_changed = False
            for appid, _ in games_list:
                current_opts = launch_options_by_app.get(appid, "")
                if current_opts in (target_option_no_hud, target_option_hud):
                    new_opt = target_option_hud if current_opts == target_option_no_hud else target_option_no_hud
                    for path, config in vdf_configs.items():
                        get_app_entry(config, appid)["LaunchOptions"] = new_opt
                    any_changed = True
            if any_changed:
                dirty = True
                print("\nToggled MangoHud for all optimized games.")
            else:
                print("\nNo optimized games found to toggle.")
            time.sleep(1)

        elif choice == "t" or choice.isdigit():
            if choice == "t":
                choice_idx = input("\nEnter game number to toggle: ").strip()
            else:
                choice_idx = choice

            if choice_idx.isdigit():
                idx = int(choice_idx)
                if 1 <= idx <= len(games_list):
                    appid, name = games_list[idx - 1]
                    current_opts = launch_options_by_app.get(appid, "")

                    for path, config in vdf_configs.items():
                        if current_opts == target_option_no_hud:
                            get_app_entry(config, appid)["LaunchOptions"] = target_option_hud
                            action = "Enabled with MangoHud"
                        elif current_opts == target_option_hud:
                            entry = get_app_entry_safe(config, appid)
                            if entry:
                                entry.pop("LaunchOptions", None)
                            action = "Disabled"
                        else:
                            get_app_entry(config, appid)["LaunchOptions"] = target_option_no_hud
                            action = "Enabled without MangoHud"

                    dirty = True
                    print(f"\n{action} for {name}.")
                    time.sleep(1)
                else:
                    print("\nInvalid game index.")
                    time.sleep(1)
            else:
                print("\nInvalid game index.")
                time.sleep(1)
        else:
            print("\nInvalid option. Please try again.")
            time.sleep(1)

# --- Usage & Main ---

def usage():
    script_name = os.path.basename(sys.argv[0])
    help_text = f"""Usage: {script_name} [OPTIONS] -- <game command>

A Steam launch wrapper that sets up GPU-specific environment variables,
applies per-game Proton overrides, and runs the game inside Gamescope.

Options:
  -m, --monitor <selector>  Choose the target monitor for Gamescope resolution.
                            Selectors:
                              workspace:<N>   Monitor hosting workspace N (default: workspace:1)
                              focused         Currently focused monitor
                              <name>          Monitor name, e.g. DP-1, HDMI-A-1
  -i, --install, --setup    Run the interactive installer to list and configure
                            steam-optimize (and MangoHud) for your games.
  --mangohud                Enable MangoHud with a discrete horizontal top bar.
  -h, --help                Show this help message and exit

Examples:
  # Default: use the monitor that has workspace 1
  {script_name} -- %command%

  # Use the currently focused monitor
  {script_name} --monitor focused -- %command%

  # Launch with MangoHud enabled
  {script_name} --mangohud -- %command%

  # Use workspace 2's monitor
  {script_name} --monitor workspace:2 -- %command%

  # Use a specific output by name with MangoHud
  {script_name} --monitor DP-1 --mangohud -- %command%

Steam launch option (add before %command%):
  {script_name} -- %command%

Logs:
  journalctl -t steam-optimize -f"""
    print(help_text)

def parse_args():
    argv = sys.argv[1:]
    monitor_selector = "workspace:1"
    install_mode = False
    mangohud = False
    game_cmd = []
    
    idx = 0
    while idx < len(argv):
        arg = argv[idx]
        if arg in ("-h", "--help"):
            usage()
            sys.exit(0)
        elif arg in ("-i", "--install", "--setup"):
            install_mode = True
            idx += 1
        elif arg == "--mangohud":
            mangohud = True
            idx += 1
        elif arg in ("-m", "--monitor"):
            if idx + 1 >= len(argv):
                print("Error: --monitor requires an argument", file=sys.stderr)
                usage()
                sys.exit(1)
            monitor_selector = argv[idx + 1]
            idx += 2
        elif arg == "--":
            game_cmd = argv[idx + 1:]
            break
        elif arg.startswith("-"):
            print(f"Error: unknown option '{arg}'", file=sys.stderr)
            usage()
            sys.exit(1)
        else:
            game_cmd = argv[idx:]
            break
            
    return install_mode, monitor_selector, mangohud, game_cmd

def main():
    install_mode, monitor_selector, mangohud, game_cmd = parse_args()
    
    script_abs_path = os.path.abspath(sys.argv[0])
    
    if install_mode:
        run_installer(script_abs_path)
        sys.exit(0)
        
    if not game_cmd:
        print("Error: no game command specified", file=sys.stderr)
        usage()
        sys.exit(1)

    collector.start()

    gamescope_supports_output = setup_global_env()
    setup_hyprland_env()
    
    if mangohud:
        os.environ["MANGOHUD"] = "1"
        os.environ["MANGOHUD_CONFIG"] = "horizontal,legacy_layout=0,hud_no_margin,font_size=15,background_alpha=0.4,gpu_stats,gpu_temp,cpu_stats,cpu_temp,ram,fps,frame_timing=0,position=top-center"
        log_info("MangoHud enabled with a discrete horizontal top-center layout")
        collector.mangohud = True
        
    steam_app_id = os.environ.get("SteamAppId", "")
    game_name, cmd = apply_game_overrides(steam_app_id, game_cmd)
    collector.game_name = game_name
    
    if cmd and cmd[0] != "gamescope":
        gs_args = get_gamescope_args(monitor_selector, gamescope_supports_output)
        cmd = ["gamescope"] + gs_args + ["--"] + cmd
        log_info(f"Applying Gamescope wrapper for {game_name}")
    else:
        collector.gamescope = "Disabled"
        
    log_info_silent(f"Launching: game-performance {' '.join(cmd)}")
    hyprland_start()
    
    collector.collecting = False
    log_info(collector.get_startup_message())
    
    start_time = int(time.time())
    hypr_success = True
    try:
        subprocess.run(["systemd-inhibit", "--what=idle", "--who=steam-optimize", "--why=Steam game running", "game-performance"] + cmd)
    finally:
        hypr_success = hyprland_end()
        
    elapsed = int(time.time()) - start_time
    hours, remainder = divmod(elapsed, 3600)
    minutes, seconds = divmod(remainder, 60)
    duration = f"{hours:02d}:{minutes:02d}:{seconds:02d}"
    
    end_lines = [
        f"🎮 Steam Optimize: {game_name}",
        "",
        f"  • Session ended (play time: {duration})"
    ]
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        if hypr_success:
            end_lines.append("  • Hyprland configuration restored")
        else:
            end_lines.append("  ⚠️ Hyprland configuration restore failed")
            
    log_info("\n".join(end_lines))

if __name__ == "__main__":
    main()
