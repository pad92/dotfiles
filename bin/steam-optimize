#!/usr/bin/env bash
# steam-optimize: Sets up performance environment variables and game-specific
# overrides before delegating execution to game-performance.
# View logs with: journalctl -t steam-optimize -f

# https://notes.depad.fr/linux/2026/05/steam-optimize-le-wrapper-ultime-pour-le-gaming-sous-linux/

set -euo pipefail

# --- Configuration ---

# Common environment variables applied to all GPUs
readonly COMMON_ENV_VARS=(
    # Proton/Wayland Optimizations
    "PROTON_ENABLE_WAYLAND=1"                 # Enables Wayland support via Proton.
    "PROTON_NO_WM_DECORATION=1"               # Disables window manager decorations within Proton.
    "PROTON_USE_NTSYNC=1"                     # Uses NTSync for improved input/timing accuracy.
    "PROTON_XESS_UPGRADE=1"                   # Enables Proton's XeSS upgrade.
    "vblank_mode=0"                           # Disables vertical blanking mode (VSync) for Mesa.
)

# AMD/Radeon specific environment variables
readonly AMD_ENV_VARS=(
    # Graphics Drivers/Layers
    "AMD_VULKAN_ICD=RADV"                     # Sets Vulkan ICD to RADV driver for AMD GPUs.
    "ENABLE_LAYER_MESA_ANTI_LAG=1"            # Enables a Mesa anti-lag layer for better performance.
    "MESA_SHADER_CACHE_MAX_SIZE=20G"          # Sets the maximum size of the Mesa shader cache (20GB).
    "__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1"   # Prevents cleanup of the OpenGL shader disk cache.
    "PROTON_FSR4_RDNA3_UPGRADE=1"             # Enables FSR 4 upgrade specifically for RDNA3 hardware.
    "PROTON_FSR4_UPGRADE=1"                   # Enables general FSR 4 upgrade support.

    # Advanced/Other Configs
    "RADV_PERFTEST=nggc,gpl"                  # Enables stable performance features in RADV (disabled unstable rt/video_decode).
    "VKD3D_CONFIG=dxr"                        # Configures VKD3D to use DirectX Ray Tracing (DXR).
)

# NVIDIA specific environment variables
readonly NVIDIA_ENV_VARS=(
    # Graphics Drivers/Layers
    "__GLX_VENDOR_LIBRARY_NAME=nvidia"        # Forces NVIDIA proprietary OpenGL driver.
    "__NV_PRIME_RENDER_OFFLOAD=1"             # Offloads rendering to NVIDIA GPU (hybrid laptops).
    "__VK_LAYER_NV_optimus=NVIDIA_only"       # Vulkan layer for hybrid laptops offloading.
    "__GL_SHADER_DISK_CACHE=1"                # Enables OpenGL shader disk cache.
    "__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1"   # Prevents cleanup of OpenGL shader cache.
    "__GL_THREADED_OPTIMIZATIONS=1"           # Enables threaded optimization for OpenGL.

    # Proton/DLSS Optimizations
    "PROTON_ENABLE_NVAPI=1"                   # Enables NVIDIA NVAPI (needed for DLSS/Reflex).
    "PROTON_HIDE_NVIDIA_GPU=0"                # Exposes NVIDIA GPU (required for NVAPI/DLSS).
    "__GL_SYNC_TO_VBLANK=0"                   # Disables VSync for OpenGL applications.
)

# Paths
readonly BATTLEYE_RUNTIME_PATH="/mnt/games/SteamLibrary/steamapps/common/Proton BattlEye Runtime"

# Constants
TAG=$(basename "$0"); readonly TAG
STEAM_APP_ID="${SteamAppId:-}"; readonly STEAM_APP_ID
USER_ID=$(id -u); readonly USER_ID
readonly RUNTIME_DIR="/run/user/${USER_ID}"

# Monitor selection: "workspace:N" (default), "focused", or a monitor name (e.g. "DP-1")
MONITOR_SELECTOR="workspace:1"

# Game command array, populated by parse_args and potentially modified by apply_game_overrides
declare -a GAME_CMD=()

# GAME_NAME is set by apply_game_overrides and read by main after the game exits
GAME_NAME=""

# Whether Gamescope supports -O/--prefer-output; resolved once in setup_global_env
GAMESCOPE_SUPPORTS_OUTPUT=false

# --- Usage ---

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] -- <game command>

A Steam launch wrapper that sets up GPU-specific environment variables,
applies per-game Proton overrides, and runs the game inside Gamescope.

Options:
  -m, --monitor <selector>  Choose the target monitor for Gamescope resolution.
                            Selectors:
                              workspace:<N>   Monitor hosting workspace N (default: workspace:1)
                              focused         Currently focused monitor
                              <name>          Monitor name, e.g. DP-1, HDMI-A-1
  -h, --help                Show this help message and exit

Examples:
  # Default: use the monitor that has workspace 1
  $(basename "$0") -- %command%

  # Use the currently focused monitor
  $(basename "$0") --monitor focused -- %command%

  # Use workspace 2's monitor
  $(basename "$0") --monitor workspace:2 -- %command%

  # Use a specific output by name
  $(basename "$0") --monitor DP-1 -- %command%

Steam launch option (add before %command%):
  steam-optimize -- %command%

Logs:
  journalctl -t steam-optimize -f
EOF
}

# --- Logging ---

_log() {
    local LEVEL="$1"
    local ICON="${2:-}"   # empty = silent (logger only, no desktop notification)
    local MSG="$3"

    logger -t "${TAG}" "${LEVEL} [${STEAM_APP_ID}] ${MSG}"

    [[ -z "${ICON}" ]] && return 0

    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        hyprctl notify "${ICON}" 5000 0 "${MSG}" 2>/dev/null || true
        return 0
    fi
    notify-send "${MSG}" 2>/dev/null || true
}

log_info_silent() { _log "INFO" ""  "$1"; }
log_info()        { _log "INFO"  1  "$1"; }
log_warn()        { _log "WARN"  0  "$1"; }
log_error()       { _log "ERROR" 3  "$1"; }

# --- Global Environment Setup ---

# Exports all entries of a named array as environment variables.
# Usage: export_vars ARRAY_NAME
export_vars() {
    local -n _VARS="$1"
    for VAR in "${_VARS[@]}"; do
        export "$VAR"
    done
}

setup_global_env() {
    # Raise the open file descriptor limit; required by heavily-threaded Proton games
    ulimit -n 1048576 || log_warn "Failed to raise ulimit"

    export_vars COMMON_ENV_VARS

    local GPU_DETECTED=false

    # Check for AMD GPU (amdgpu kernel module loaded)
    if [[ -d /sys/module/amdgpu ]]; then
        log_info "AMD GPU detected (amdgpu module loaded) — applying RADV optimizations"
        export_vars AMD_ENV_VARS
        GPU_DETECTED=true
    fi

    # Check for NVIDIA GPU (nvidia kernel module loaded)
    if [[ -d /sys/module/nvidia ]]; then
        log_info "NVIDIA GPU detected (nvidia module loaded) — applying proprietary optimizations"
        export_vars NVIDIA_ENV_VARS
        GPU_DETECTED=true
    fi

    if [[ "${GPU_DETECTED}" = false ]]; then
        log_warn "No specific GPU module (amdgpu/nvidia) detected — using common defaults"
    fi

    # Probe Gamescope capabilities once to avoid repeated forks later
    if gamescope --help 2>&1 | grep -q -- '--prefer-output'; then
        GAMESCOPE_SUPPORTS_OUTPUT=true
    else
        log_warn "Gamescope does not support -O/--prefer-output; monitor pinning will be skipped"
    fi
}

# --- Hyprland Integration ---

setup_hyprland_env() {
    export XDG_RUNTIME_DIR="${RUNTIME_DIR}"

    if [[ -d "${RUNTIME_DIR}/hypr" ]]; then
        # Use the most recently created socket to target the active Hyprland instance
        export HYPRLAND_INSTANCE_SIGNATURE
        HYPRLAND_INSTANCE_SIGNATURE=$(ls -t "${RUNTIME_DIR}/hypr" | head -n 1)
    fi
}

# Returns Gamescope resolution and output flags for the selected monitor.
# Monitor selection is controlled by MONITOR_SELECTOR:
#   "workspace:N"  — monitor hosting Hyprland workspace N (default: workspace:1)
#   "focused"      — currently focused monitor
#   "<name>"       — monitor name as reported by hyprctl (e.g. DP-1, HDMI-A-1)
# Falls back to no resolution flags if Hyprland or jq is unavailable, or if
# no matching monitor is found.
get_gamescope_args() {
    local -a ARGS=(-f --force-grab-cursor)

    if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        echo "${ARGS[*]}"
        return 0
    fi

    if ! command -v jq >/dev/null 2>&1; then
        log_warn "jq not found; Gamescope will use default resolution"
        echo "${ARGS[*]}"
        return 0
    fi

    local MONITORS
    MONITORS=$(hyprctl monitors -j 2>/dev/null) || true

    if [[ -z "${MONITORS}" ]]; then
        log_warn "hyprctl monitors returned no data; Gamescope will use default resolution"
        echo "${ARGS[*]}"
        return 0
    fi

    local RES_W="" RES_H="" MON_NAME=""
    local JQ_FILTER=""

    case "${MONITOR_SELECTOR}" in
        focused)
            JQ_FILTER='.[] | select(.focused == true)'
            ;;
        workspace:*)
            local WS_ID="${MONITOR_SELECTOR#workspace:}"
            JQ_FILTER=".[] | select(.activeWorkspace.id == ${WS_ID})"
            if ! jq -e "${JQ_FILTER}" <<< "${MONITORS}" >/dev/null 2>&1; then
                log_warn "No monitor found with workspace ${WS_ID}; Gamescope will use default resolution"
                echo "${ARGS[*]}"
                return 0
            fi
            ;;
        *)
            JQ_FILTER=".[] | select(.name == \"${MONITOR_SELECTOR}\")"
            if ! jq -e "${JQ_FILTER}" <<< "${MONITORS}" >/dev/null 2>&1; then
                log_warn "Monitor '${MONITOR_SELECTOR}' not found; Gamescope will use default resolution"
                echo "${ARGS[*]}"
                return 0
            fi
            ;;
    esac

    # Single jq call to extract all four fields at once (rounding the refresh rate)
    local MON_REFRESH=""
    IFS=$'\t' read -r RES_W RES_H MON_NAME MON_REFRESH < <(
        jq -r "${JQ_FILTER} | [.width, .height, .name, (.refreshRate | round)] | @tsv" <<< "${MONITORS}" 2>/dev/null || true
    )

    if [[ -n "${RES_W}" && "${RES_W}" != "null" ]]; then
        ARGS=(-W "${RES_W}" -H "${RES_H}" -w "${RES_W}" -h "${RES_H}" "${ARGS[@]}")
    fi

    # Pin the virtual screen refresh rate to match the monitor's native frequency
    if [[ -n "${MON_REFRESH}" && "${MON_REFRESH}" != "null" && "${MON_REFRESH}" != "0" ]]; then
        ARGS+=(-r "${MON_REFRESH}")
    fi

    # -O <connector> pins Gamescope to the target output (--prefer-output).
    # The connector name reported by hyprctl (e.g. DP-1, HDMI-A-1) matches the DRM
    # connector name that Gamescope expects.
    if [[ -n "${MON_NAME}" && "${MON_NAME}" != "null" && "${GAMESCOPE_SUPPORTS_OUTPUT}" == true ]]; then
        ARGS+=(-O "${MON_NAME}")
    fi

    echo "${ARGS[*]}"
}

# Disables Hyprland effects that waste GPU time during gameplay
hyprland_start() {
    [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]] && return 0

    log_info "Optimizing Hyprland for gaming"
    makoctl mode -s dnd 2>/dev/null || true

    # Disable animations, shadows, blur and opacity effects atomically.
    # Note: hl.config() is an experimental Hyprland API; failures are non-fatal.
    if ! hyprctl eval "
      hl.config({
        animations = { enabled = false },
        decoration = {
          rounding = 0,
          active_opacity = 1.0,
          inactive_opacity = 1.0,
          shadow = { enabled = false },
          blur = { enabled = false }
        }
      })
    " 2>/dev/null; then
        log_warn "Failed to apply Hyprland rendering optimizations (hl.config unavailable?)"
    fi

    # Prevent the idle daemon from locking the screen mid-game
    systemctl --user stop hypridle.service 2>/dev/null || true
}

# Restores the desktop to its normal state after the game exits
hyprland_end() {
    razer-cli -d 1600 2>/dev/null || true

    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        log_info "Restoring Hyprland configuration"
        hyprctl reload 2>/dev/null || log_error "Failed to reload Hyprland configuration"
        makoctl mode -s default 2>/dev/null || true
    fi

    # Only restart hypridle if it is not already running (e.g. was stopped above)
    if ! systemctl --user is-active hypridle.service >/dev/null 2>&1; then
        systemctl --user reset-failed hypridle.service 2>/dev/null || true
        systemctl --user start hypridle.service 2>/dev/null || true
    fi
}

# --- Game Configuration Helpers ---

# Configures Proton's BattlEye runtime for games that require it.
enable_battleye() {
    export PROTON_BATTLEYE_RUNTIME="${BATTLEYE_RUNTIME_PATH}"
    export PROTON_BATTLEYE_RUNTIME_ALWAYS_COPY=1
    export PROTON_BATTLEYE_RUNTIME_LEGACY_EXEC=1
}

# Switches to Proton's native Wayland backend: clears XWayland fallback hints
# and disables Steam Input. Call after setting GAME_NAME.
# Pass --keep-steaminput to skip disabling Steam Input (e.g. World of Warships).
use_native_wayland() {
    unset SDL_VIDEODRIVER
    unset __GLX_VENDOR_LIBRARY_NAME
    if [[ "${1:-}" != "--keep-steaminput" ]]; then
        export PROTON_NO_STEAMINPUT=1
    fi
    log_info "Applying native Wayland optimizations for ${GAME_NAME}"
}

# --- Per-game Overrides ---

apply_game_overrides() {
    case "${STEAM_APP_ID}" in
        "1808500")
            GAME_NAME="Arc Raiders"
            razer-cli -d 800 2>/dev/null || true
            use_native_wayland
            ;;
        "526870")
            GAME_NAME="Satisfactory"
            use_native_wayland
            ;;
        "552990")
            # World of Warships uses native Wayland but keeps Steam Input enabled
            GAME_NAME="World of Warships"
            use_native_wayland --keep-steaminput
            ;;
        "271590"|"3240220")
            GAME_NAME="Grand Theft Auto V"
            [[ "${STEAM_APP_ID}" = "3240220" ]] && GAME_NAME="Grand Theft Auto V Enhanced"
            razer-cli -d 800 2>/dev/null || true
            enable_battleye
            export PROTON_NO_STEAMINPUT=1
            log_info "Applying BattlEye overrides for ${GAME_NAME}"
            ;;
        "899770")
            GAME_NAME="Last Epoch"
            # Narrower RADV feature set avoids a rendering regression in Last Epoch
            export RADV_PERFTEST='nggc,gpl'
            use_native_wayland
            ;;
        "412020"|"1449560")
            GAME_NAME="Metro Exodus"
            use_native_wayland
            ;;
        "379720")
            GAME_NAME="DOOM"
            # mesa_glthread improves CPU-side OpenGL throughput for this title
            export mesa_glthread=true
            # DOOM does not support Proton Wayland; revert to XWayland via Gamescope
            unset PROTON_ENABLE_WAYLAND
            # Add game-specific arguments to the command array
            GAME_CMD+=("+com_skipIntroVideo" "1" "+set" "m_smooth" "0")
            ;;
        "13240")
            GAME_NAME="Unreal Tournament GOTY"
            use_native_wayland
            ;;
        "2483190")
            GAME_NAME="Forza Horizon 6"
            export VKD3D_CONFIG=no_upload_hvv,single_queue
            export PROTON_SET_GAME_DRIVE=1
            export WINEDLLOVERRIDES="winmm=n,b;steam_api64=n,b;version=n,b"
            export SDL_VIDEODRIVER=x11
            ;;
        *)
            GAME_NAME="AppID:${STEAM_APP_ID}"
            log_info "No game-specific overrides; using default settings"
            ;;
    esac

    # Wrap all games in Gamescope if not already wrapped
    if [[ "${GAME_CMD[0]}" != "gamescope" ]]; then
        local GAMESCOPE_ARGS
        GAMESCOPE_ARGS=$(get_gamescope_args)
        # Word-splitting of gamescope_args is intentional: it contains only short flags
        # shellcheck disable=SC2086
        GAME_CMD=(gamescope ${GAMESCOPE_ARGS} -- "${GAME_CMD[@]}")
        log_info "Applying Gamescope wrapper for ${GAME_NAME}"
    fi
}

# --- Argument Parsing ---

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -m|--monitor)
                if [[ -z "${2:-}" ]]; then
                    echo "Error: --monitor requires an argument" >&2
                    usage >&2
                    exit 1
                fi
                MONITOR_SELECTOR="$2"
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Error: unknown option '$1'" >&2
                usage >&2
                exit 1
                ;;
            *)
                # No leading dash: treat as start of game command (no '--' separator used)
                break
                ;;
        esac
    done

    GAME_CMD=("$@")
}

# --- Entry Point ---

main() {
    parse_args "$@"

    if [[ ${#GAME_CMD[@]} -eq 0 ]]; then
        echo "Error: no game command specified" >&2
        usage >&2
        exit 1
    fi

    setup_global_env
    setup_hyprland_env
    apply_game_overrides

    # Ensure the desktop is restored even if game-performance crashes or is killed
    trap hyprland_end EXIT

    log_info_silent "Launching: game-performance ${GAME_CMD[*]}"
    hyprland_start

    # $EPOCHSECONDS is a bash built-in: no subshell, no date overhead
    local START_TIME=$EPOCHSECONDS
    game-performance "${GAME_CMD[@]}"

    local ELAPSED=$(( EPOCHSECONDS - START_TIME ))
    local SESSION_DURATION
    SESSION_DURATION=$(printf "%02d:%02d:%02d" \
        $(( ELAPSED / 3600 )) \
        $(( (ELAPSED % 3600) / 60 )) \
        $(( ELAPSED % 60 )))
    log_info "${GAME_NAME} — session ended, play time: ${SESSION_DURATION}"
}

main "$@"
