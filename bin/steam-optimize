#!/bin/sh

export PROTON_USE_NTSYNC=1
export PROTON_FSR4_UPGRADE=1
export PROTON_FSR4_RDNA3_UPGRADE=1
export PROTON_XESS_UPGRADE=1
export ENABLE_LAYER_MESA_ANTI_LAG=1
export RADV_PERFTEST='rt,nggc,gpl'
export PROTON_NO_STEAMINPUT=1
export AMD_VULKAN_ICD=RADV
export vblank_mode=0
export PROTON_NO_WM_DECORATION=1
export MESA_SHADER_CACHE_MAX_SIZE=12G
export __GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1

# --- HYPRLAND SETUP ---
USER_ID=$(id -u)
RUNTIME_DIR="/run/user/$USER_ID"
if [ -d "$RUNTIME_DIR/hypr" ]; then
    export HYPRLAND_INSTANCE_SIGNATURE=$(ls -t "$RUNTIME_DIR/hypr" | head -n 1)
    export XDG_RUNTIME_DIR="$RUNTIME_DIR"
fi

TAG=$(basename "$0")

# --- LOGGING FUNCTION ---
log_info() {
    # Logs to syslog (view with: journalctl -t steam-optimize -f)
    logger -t "$TAG" "$SteamAppId : $1"
    notify-send "$1"
}

hyprland_start() {
    if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
        log_info "Optimizing Hyprland for gaming..."
        hyprctl --batch "keyword animations:enabled 0;\
                        keyword decoration:shadow:enabled 0;\
                        keyword decoration:blur:enabled 0;\
                        keyword decoration:rounding 0;\
                        keyword decoration:active_opacity 1.0;\
                        keyword decoration:inactive_opacity 1.0" || log_info "Warning: Failed to apply Hyprland optimizations"
    fi
    systemctl --user stop hypridle.service 2>/dev/null || true
}

hyprland_end() {
    if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
        log_info "Restoring Hyprland configuration..."
        hyprctl reload || log_info "Warning: Failed to reload Hyprland configuration"
    fi
    if ! systemctl --user is-active hypridle.service >/dev/null 2>&1; then
        systemctl --user reset-failed hypridle.service 2>/dev/null || true
        systemctl --user start hypridle.service 2>/dev/null || true
    fi
}

# --- PER-GAME OVERRIDES ---
case "$SteamAppId" in
    "1808500")
        # Specific settings for Arc Raiders
        export PROTON_ENABLE_WAYLAND=1
        unset SDL_VIDEODRIVER
        unset __GLX_VENDOR_LIBRARY_NAME
        log_info "Applying native Wayland optimizations for Arc Raiders."
        ;;
    "526870")
        # Specific settings for Satisfactory
        export PROTON_ENABLE_WAYLAND=1
        unset SDL_VIDEODRIVER
        unset __GLX_VENDOR_LIBRARY_NAME
        log_info "Applying native Wayland optimizations for Satisfactory."
        ;;
    "552990")
        # Specific settings for World of Warships
        export PROTON_ENABLE_WAYLAND=1
        unset SDL_VIDEODRIVER
        unset __GLX_VENDOR_LIBRARY_NAME
        log_info "Applying native Wayland optimizations for World of Warships."
        ;;
    *)
        # Default settings for other games
        export PROTON_ENABLE_WAYLAND=0
        log_info "Applying default settings (XWayland)."
        ;;
esac

hyprland_start
log_info "Starting game-performance with arguments: $@"
game-performance "$@"
hyprland_end
