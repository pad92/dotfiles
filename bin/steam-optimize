#!/usr/bin/env python3
# steam-optimize: Sets up performance environment variables and game-specific
# overrides before delegating execution to game-performance.
# View logs with: journalctl -t steam-optimize -f

# https://notes.depad.fr/linux/2026/05/steam-optimize-le-wrapper-ultime-pour-le-gaming-sous-linux/

import os
import sys
import time
import json
import subprocess
import shutil

# --- Configuration ---

# Common environment variables applied to all GPUs
COMMON_ENV_VARS = {
    "PROTON_ENABLE_WAYLAND": "1",                 # Enables Wayland support via Proton.
    "PROTON_NO_WM_DECORATION": "1",               # Disables window manager decorations within Proton.
    "PROTON_USE_NTSYNC": "1",                     # Uses NTSync for improved input/timing accuracy.
    "PROTON_XESS_UPGRADE": "1",                   # Enables Proton's XeSS upgrade.
    "vblank_mode": "0",                           # Disables vertical blanking mode (VSync) for Mesa.
    "SDL_VIDEO_MINIMIZE_ON_FOCUS_LOSS": "0",      # Prevents window from minimizing when focus is lost.
}

# AMD/Radeon specific environment variables
AMD_ENV_VARS = {
    "AMD_VULKAN_ICD": "RADV",                     # Sets Vulkan ICD to RADV driver for AMD GPUs.
    "ENABLE_LAYER_MESA_ANTI_LAG": "1",            # Enables a Mesa anti-lag layer for better performance.
    "MESA_SHADER_CACHE_MAX_SIZE": "20G",          # Sets the maximum size of the Mesa shader cache (20GB).
    "__GL_SHADER_DISK_CACHE_SKIP_CLEANUP": "1",   # Prevents cleanup of the OpenGL shader disk cache.
    "PROTON_FSR4_RDNA3_UPGRADE": "1",             # Enables FSR 4 upgrade specifically for RDNA3 hardware.
    "PROTON_FSR4_UPGRADE": "1",                   # Enables general FSR 4 upgrade support.
    "RADV_PERFTEST": "nggc,gpl",                  # Enables stable performance features in RADV.
    "VKD3D_CONFIG": "dxr",                        # Configures VKD3D to use DirectX Ray Tracing (DXR).
}

# NVIDIA specific environment variables
NVIDIA_ENV_VARS = {
    "__GLX_VENDOR_LIBRARY_NAME": "nvidia",        # Forces NVIDIA proprietary OpenGL driver.
    "__NV_PRIME_RENDER_OFFLOAD": "1",             # Offloads rendering to NVIDIA GPU.
    "__VK_LAYER_NV_optimus": "NVIDIA_only",       # Vulkan layer for hybrid laptops offloading.
    "__GL_SHADER_DISK_CACHE": "1",                # Enables OpenGL shader disk cache.
    "__GL_SHADER_DISK_CACHE_SKIP_CLEANUP": "1",   # Prevents cleanup of OpenGL shader cache.
    "__GL_THREADED_OPTIMIZATIONS": "1",           # Enables threaded optimization for OpenGL.
    "PROTON_ENABLE_NVAPI": "1",                   # Enables NVIDIA NVAPI (needed for DLSS/Reflex).
    "PROTON_HIDE_NVIDIA_GPU": "0",                # Exposes NVIDIA GPU (required for NVAPI/DLSS).
    "__GL_SYNC_TO_VBLANK": "0",                   # Disables VSync for OpenGL applications.
}

